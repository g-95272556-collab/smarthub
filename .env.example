# SmartSchoolHub local/deployment environment example
# Salin ke .env untuk nota tempatan sahaja. Jangan commit .env sebenar.

# Frontend/runtime public config. Nilai ini boleh dilihat oleh browser.
SMARTSCHOOLHUB_WORKER_URL=https://smartschoolhub-skkiandongo.g-95272556.workers.dev
SMARTSCHOOLHUB_GOOGLE_AUTH_URL=https://smartschoolhub-google-oauth.g-95272556.workers.dev
SMARTSCHOOLHUB_GOOGLE_CLIENT_ID=553204925712-p975t8hnehd4vfhs3igf4ba9c63edf0f.apps.googleusercontent.com
SMARTSCHOOLHUB_LAUNCH_DATE=2026-06-08

# Cloudflare Worker secrets. Set menggunakan wrangler secret, bukan dalam source code.
WORKER_SECRET=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_API_CLIENT_SECRET=
GOOGLE_API_REFRESH_TOKEN=

# Optional Google Sheets backend vars. Spreadsheet ID bukan secret, tetapi tetap operational config.
GOOGLE_SHEETS_BACKEND=0
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_API_CLIENT_ID=

# OAuth worker config.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_IDS=
GOOGLE_ALLOWED_EMAIL_DOMAINS=moe-dl.edu.my
ALLOWED_ORIGINS=https://xbasmarthub.netlify.app

# Notification tokens. Prefer platform secret/backend config, bukan source code.
TELEGRAM_BOT=
TELEGRAM_CHAT=
TELEGRAM_TOPIC=
FONNTE_TOKEN=
